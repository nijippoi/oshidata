{
  "tasks": {
    "clean": "rm -rf dist/",
    "format": "deno fmt",
    "import": "deno run --allow-read --allow-write scripts/import.ts data/ src/data/",
    "build": {
      "command": "deno bundle --inline-imports=true --platform=browser --sourcemap=linked --outdir dist src/index.html",
      "dependencies": ["clean", "import"]
    },
    "release": {
      "command": "deno bundle --minify --inline-imports=true --platform=browser --sourcemap=linked --outdir dist src/index.html",
      "dependencies": ["clean", "import"]
    },
    "dev": {
      "command": "deno bundle --watch --inline-imports=true --platform=browser --sourcemap=linked --outdir dist src/index.html",
      "dependencies": ["clean", "import"]
    }
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@std/yaml": "jsr:@std/yaml@^1.0.12"
  },
  "fmt": {
    "exclude": [
      "dist/",
      "src/data/"
    ],
    "lineWidth": 120,
    "singleQuote": true
  }
}
