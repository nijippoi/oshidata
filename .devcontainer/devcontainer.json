{
  "name": "oshidata",
  "image": "mcr.microsoft.com/devcontainers/base:trixie",
  "mounts": [
    {
      "type": "volume",
      "source": "${devcontainerId}-apt-cache",
      "target": "/var/apt/cache"
    },
    {
      "type": "volume",
      "source": "${devcontainerId}-user-cache",
      "target": "/home/vscode/.cache"
    }
  ],
  "features": {
    "ghcr.io/devcontainers-community/features/deno:1": {
      "version": "2.7.9"
    }
  },
  "onCreateCommand": "sudo chown $(id -u):$(id -g) /home/$(id -u -n)/.cache",
  "postCreateCommand": "deno task install",
  "customizations": {
    "extensions": [
      "denoland.vscode-deno",
      "github.vscode-github-actions",
      "ms-vscode.live-server"
    ],
    "vscode": {
      "[css]": {
        "editor.defaultFormatter": "denoland.vscode-deno",
        "editor.tabSize": 2,
        "editor.insertSpaces": true
      },
      "[json]": {
        "editor.defaultFormatter": "denoland.vscode-deno",
        "editor.tabSize": 2,
        "editor.insertSpaces": true
      },
      "[jsonc]": {
        "editor.defaultFormatter": "denoland.vscode-deno",
        "editor.tabSize": 2,
        "editor.insertSpaces": true
      },
      "[jsonl]": {
        "editor.defaultFormatter": "denoland.vscode-deno",
        "editor.tabSize": 2,
        "editor.insertSpaces": true
      },
      "[yaml]": {
        "editor.defaultFormatter": "denoland.vscode-deno",
        "editor.tabSize": 2,
        "editor.insertSpaces": true
      },
      "[javascript]": {
        "editor.defaultFormatter": "denoland.vscode-deno",
        "editor.formatOnSave": true,
        "editor.tabSize": 2,
        "editor.insertSpaces": true
      },
      "[typescript]": {
        "editor.defaultFormatter": "denoland.vscode-deno",
        "editor.formatOnSave": true,
        "editor.tabSize": 2,
        "editor.insertSpaces": true
      },
      "[html]": {
        "editor.defaultFormatter": "denoland.vscode-deno",
        "editor.formatOnSave": true,
        "editor.tabSize": 2,
        "editor.insertSpaces": true
      },
      "chat.tools.terminal.autoApprove": {
        "deno": true
      },
      "telemetry.telemetryLevel": "off"
    }
  }
}
