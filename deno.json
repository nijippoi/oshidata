{
  "name": "oshidata",
  "version": "0.0.1",
  "description": "",
  "compilerOptions": {
    "lib": [
      "deno",
      "deno.ns",
      "deno.window",
      "deno.unstable",
      "esnext",
      "dom"
    ]
  },
  "tasks": {
    "install": "deno install -I",
    "update": "deno update -I",
    "format": "deno fmt",
    "check": "deno fmt --check",
    "clean": "deno run -RW ./tasks/clean.ts",
    "import": "deno run -RW ./tasks/import.ts",
    "import-dev": "deno run -RW ./tasks/import.ts --no-release",
    "bundle": {
      "command": "deno run -RWNI ./tasks/bundle.ts",
      "dependencies": ["clean", "import"]
    },
    "bundle-dev": {
      "command": "deno run -RWNI ./tasks/bundle.ts --no-release --baseurl=http://127.0.0.1:3000",
      "dependencies": ["clean", "import-dev"]
    },
    "serve": "deno run -RWNI ./tasks/serve.ts"
  },
  "imports": {
    "material-symbols-outlined": "https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined",
    "@std/http": "jsr:@std/http@^1.0.25",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/cli": "jsr:@std/cli@^1.0.28",
    "@std/fs": "jsr:@std/fs@^1.0.23",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@std/yaml": "jsr:@std/yaml@^1.0.12"
  },
  "entrypoint": [],
  "exports": {
    ".": "./src/mod.ts",
    "./*": "./src/*"
  },
  "unstable": ["bundle"],
  "fmt": {
    "exclude": [
      "dist/",
      "data/",
      "labels/"
    ],
    "lineWidth": 120,
    "singleQuote": true
  }
}
